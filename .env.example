# Backend
PORT=3000

# AES-256-GCM key — must be exactly 64 hex characters (32 bytes)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_char_hex_key_here

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
# For local dev only. Do not commit the JSON file.
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/serviceAccountKey.json

# CORS — URL of the frontend (used by backend to allow cross-origin requests)
FRONTEND_URL=http://localhost:3001

# Shared edge throttles
GLOBAL_RATE_LIMIT_RPM=100
LOGIN_RATE_LIMIT_ATTEMPTS_PER_MINUTE=20
PROXY_RATE_LIMIT_PER_IP_PER_MINUTE=180
PROXY_RATE_LIMIT_PER_CLIENT_PER_MINUTE=600

# Shared-state housekeeping / provider safety
CLIENT_LAST_USED_WRITE_INTERVAL_MS=300000
PROVIDER_REQUEST_TIMEOUT_MS=30000
CUSTOM_PROVIDER_ALLOWED_HOSTS=api.openai.com,generativelanguage.googleapis.com
ALLOW_UNSAFE_CUSTOM_PROVIDER_URLS=false

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3000
